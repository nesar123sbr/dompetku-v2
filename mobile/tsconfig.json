{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./assets/*"]
    }
  },
  "include": [
    "expo-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app-example"
  ]
}