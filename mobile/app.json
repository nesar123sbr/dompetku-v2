{
  "expo": {
    "name": "DompetKu",
    "slug": "DompetKu-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/DompetKu_icon.png",
    "scheme": "dompetku",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F8FB",
        "foregroundImage": "./assets/images/DompetKu_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.gadanesar.dompetku",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Dompetku.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Dompetku.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#F7F8FB",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sqlite",
      "expo-sharing",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
      
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e25dcf5-10bc-45b3-83ca-5d3b01361bd4"
      }
    }
  }
}
